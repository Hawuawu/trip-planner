rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trips/{tripId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberIds;

      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds
        && (
          // membership-only change (remove a member) — any current member
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberProfiles'])
            && request.resource.data.memberIds.size() >= 1
            && request.resource.data.memberIds.hasOnly(resource.data.memberIds))
          ||
          // trip metadata change (rename/date range) — owner only, or unowned legacy trip
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'dateRange'])
            && (!('ownerId' in resource.data) || resource.data.ownerId == request.auth.uid))
        );

      allow delete: if request.auth != null
        && request.auth.uid in resource.data.memberIds
        && (!('ownerId' in resource.data) || resource.data.ownerId == request.auth.uid);

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
      }
    }
  }
}
